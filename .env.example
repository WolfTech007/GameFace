# Copy to `.env.local` (same folder as package.json) and fill in values from
# Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# When true, guests can open games and social routes without signing in.
# When false, those routes redirect to /login (/, /login, /signup stay public).
NEXT_PUBLIC_ALLOW_GUEST_PLAY=false
